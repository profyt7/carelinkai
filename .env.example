# ============================================================
# CareLinkAI — Environment Variables
# Copy this file to .env.local for local development
# Set all production values in Render dashboard > Environment
# ============================================================

# ------------------------------------------------------------
# DATABASE (required)
# ------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/carelinkai"

# ------------------------------------------------------------
# NEXTAUTH (required)
# ------------------------------------------------------------
NEXTAUTH_URL="https://getcarelinkai.com"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# ------------------------------------------------------------
# STRIPE — Payments (required for billing features)
# Keys from: https://dashboard.stripe.com/apikeys
# Webhook secret from: https://dashboard.stripe.com/webhooks
# ------------------------------------------------------------
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Subscription tier Price IDs — create these Products/Prices in Stripe dashboard
# When swapping Stripe accounts, update these four values along with the keys above
STRIPE_PRICE_STARTER="price_..."
STRIPE_PRICE_PROFESSIONAL="price_..."
STRIPE_PRICE_GROWTH="price_..."
# Placement fee charged to operator on inquiry → resident conversion (in cents, default $500)
PLACEMENT_FEE_CENTS=50000
# Care Wallet transaction fee percentage charged to families (default 2.5%)
WALLET_FEE_PCT=2.5
# Affiliate commission percentage of placement fee (default 20%)
DEFAULT_AFFILIATE_COMMISSION_PCT=20

# ------------------------------------------------------------
# RESEND — Transactional email (required)
# Keys from: https://resend.com/api-keys
# Verify your domain at: https://resend.com/domains
# ------------------------------------------------------------
RESEND_API_KEY="re_..."
EMAIL_FROM="noreply@getcarelinkai.com"
EMAIL_FROM_NAME="CareLinkAI"
RESEND_FROM_EMAIL="noreply@getcarelinkai.com"

# ------------------------------------------------------------
# CLOUDINARY — Image/file storage (required for uploads)
# Keys from: https://console.cloudinary.com
# ------------------------------------------------------------
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# ------------------------------------------------------------
# ANTHROPIC — All AI features (required)
# Powers: CareBot chatbot, inquiry responses, document
# classification, discharge planner search
# Keys from: https://console.anthropic.com
# ------------------------------------------------------------
ANTHROPIC_API_KEY="sk-ant-..."

# ------------------------------------------------------------
# SENTRY — Error monitoring
# DSN from: https://sentry.io > Your Project > Settings > DSN
# ------------------------------------------------------------
SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.sentry.io/xxxx"
NEXT_PUBLIC_ENVIRONMENT="production"

# ------------------------------------------------------------
# ANALYTICS (optional — all public keys)
# ------------------------------------------------------------
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
NEXT_PUBLIC_FB_PIXEL_ID="1234567890123456"
NEXT_PUBLIC_CLARITY_ID="xxxxxxxxxx"

# ------------------------------------------------------------
# APP (required)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL="https://getcarelinkai.com"

# ------------------------------------------------------------
# SENDGRID — legacy email fallback (optional if using Resend)
# ------------------------------------------------------------
# SENDGRID_API_KEY="SG...."

# ------------------------------------------------------------
# TWILIO — SMS notifications (new inquiry, tour booked, inquiry response, payment failed, tour reminders)
# ------------------------------------------------------------
TWILIO_ACCOUNT_SID="AC..."
TWILIO_AUTH_TOKEN="..."
TWILIO_PHONE_NUMBER="+1..."
# Random secret to secure the /api/cron/tour-reminders endpoint
# Generate with: openssl rand -hex 32
CRON_SECRET="..."

# ------------------------------------------------------------
# WEB PUSH — PWA push notifications (optional)
# Generate with: npm run generate:vapid
# ------------------------------------------------------------
# NEXT_PUBLIC_VAPID_PUBLIC_KEY="..."
# VAPID_PRIVATE_KEY="..."

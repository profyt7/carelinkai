  OPEN
  FILLING
  FILLED
  UNFILLED
  CANCELED
}

enum CoverageChannel {
  SMS
  VOICE
  EMAIL
}

enum CoverageOutcome {
  SENT
  CONFIRMED
  DECLINED
  ERROR
  NO_RESPONSE
}

/// An open shift coverage request that drives the On-Call AI outreach engine
model ShiftNeed {
  id                   String           @id @default(cuid())
  homeId               String
  shiftId              String?          @unique
  requiredCerts        String[]         @default([])
  requiredSkills       String[]         @default([])
  minExperienceMonths  Int?
  notes                String?
  status               ShiftNeedStatus  @default(OPEN)
  filledByCaregiverId  String?
  filledAt             DateTime?
  currentWave          Int              @default(0)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  home                 AssistedLivingHome @relation(fields: [homeId], references: [id], onDelete: Cascade)
  shift                CaregiverShift?    @relation(fields: [shiftId], references: [id])
  filledByCaregiver    Caregiver?         @relation("FilledByCaregiver", fields: [filledByCaregiverId], references: [id])
  attempts             CoverageAttempt[]

  @@index([homeId])
  @@index([status])
  @@index([createdAt])
}

/// Each outreach attempt to a caregiver for a ShiftNeed
model CoverageAttempt {
  id          String          @id @default(cuid())
  shiftNeedId String
  caregiverId String
  channel     CoverageChannel @default(SMS)
  outcome     CoverageOutcome @default(SENT)
  messageSid  String?
  notes       String?
  wave        Int             @default(1)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  shiftNeed   ShiftNeed  @relation(fields: [shiftNeedId], references: [id], onDelete: Cascade)
  caregiver   Caregiver  @relation(fields: [caregiverId], references: [id], onDelete: Cascade)

  @@index([shiftNeedId])
  @@index([caregiverId])
  @@index([messageSid])
  @@index([outcome])
}


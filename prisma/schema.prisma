model Invoice {
  id                   String        @id @default(cuid())
  operatorId           String
  stripeInvoiceId      String        @unique
  stripeSubscriptionId String?
  status               InvoiceStatus
  amountDue            Int
  amountPaid           Int           @default(0)
  currency             String        @default("usd")
  description          String?
  periodStart          DateTime?
  periodEnd            DateTime?
  invoiceUrl           String?
  invoicePdf           String?
  paidAt               DateTime?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  operator             Operator      @relation(fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([operatorId])
  @@index([stripeInvoiceId])
}

/// Per-seat subscription profile for hospital discharge planners
model DischargePlannerProfile {
  id                   String                      @id @default(cuid())
  userId               String                      @unique
  organization         String?
  title                String?
  stripeCustomerId     String?                     @unique
  stripeSubscriptionId String?                     @unique
  subscriptionStatus   SubscriptionStatus?
  licenseType          DischargePlannerLicenseType @default(INDIVIDUAL)
  seatCount            Int                         @default(1)
  trialEndsAt          DateTime?
  currentPeriodEndsAt  DateTime?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  user                 User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([stripeCustomerId])
}

enum DischargePlannerLicenseType {
  INDIVIDUAL
  DEPARTMENT
}

enum AffiliateReferralType {
  OPERATOR
  FAMILY
}

/// Families or prospects waiting for a bed at a specific home
model WaitlistEntry {
  id          String             @id @default(cuid())
  homeId      String
  familyId    String?
  name        String
  email       String
  phone       String?
  notes       String?
  priority    Int                @default(0)
  notified    Boolean            @default(false)
  notifiedAt  DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  home        AssistedLivingHome @relation(fields: [homeId], references: [id], onDelete: Cascade)
  family      Family?            @relation(fields: [familyId], references: [id], onDelete: SetNull)

  @@index([homeId])
  @@index([familyId])
  @@index([createdAt])
}


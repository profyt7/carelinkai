// System Settings Model for Admin Configuration
model SystemSettings {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  category    String   @default("general")
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([key])
}


// Export History Model for tracking data exports
model ExportHistory {
  id           String       @id @default(cuid())
  exportType   String       // users, homes, inquiries, caregivers, residents, audit-logs
  fileName     String
  recordCount  Int          @default(0)
  status       ExportStatus @default(PENDING)
  filters      Json?        // Stored filters used for the export
  format       String       @default("csv") // csv, json
  downloadUrl  String?      // Optional URL for re-download (if stored)
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  exportedById String
  exportedBy   User         @relation("UserExports", fields: [exportedById], references: [id])

  @@index([exportedById])
  @@index([exportType])
  @@index([createdAt])
}

enum ExportStatus {
  PENDING
  COMPLETED
  FAILED
}

